# Absolute path to the built site publish directory on the VPS.
PUBLIC_DIR=/var/www/kcwweb

# Optional override for the app directory inside the repository.
APP_DIR=

# Optional backup root. Leave empty to store backups next to the publish path.
BACKUP_ROOT=

# true | false
ENABLE_BACKUP=true

# Optional command executed after publish. Example:
# RELOAD_COMMAND=sudo systemctl reload nginx
RELOAD_COMMAND=
